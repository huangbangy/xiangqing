.avatar-copy {
  flex: 1;
  min-width: 0;
}

.choose-btn {
  margin-top: 16rpx;
  width: 220rpx;
}

.upload-bar {
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(217, 91, 79, 0.1);
  color: #9e4238;
  font-size: 24rpx;
}

.photo-empty {
  padding: 30rpx;
}

.contact-note {
  min-height: 120rpx;
}

.short-textarea {
  min-height: 132rpx;
}

.tag-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag-toggle {
  height: 54rpx;
  line-height: 54rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(139, 63, 52, 0.1);
  color: #72564d;
  font-size: 24rpx;
}

.tag-toggle-active {
  background: #2b2522;
  color: #fff8f3;
}

.tag-hint {
  margin-top: 12rpx;
}

.match-question + .match-question {
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(139, 63, 52, 0.1);
}

.match-options {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.match-option {
  height: 54rpx;
  line-height: 54rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(139, 63, 52, 0.1);
  color: #72564d;
  font-size: 24rpx;
}

.match-option-active {
  background: #d95b4f;
  color: #ffffff;
  border-color: #d95b4f;
  box-shadow: 0 12rpx 28rpx rgba(217, 91, 79, 0.22);
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.photo-item {
  position: relative;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  border-radius: 16rpx;
  background: rgba(126, 156, 134, 0.1);
  border: 1rpx solid rgba(139, 63, 52, 0.08);
}

.photo-item image {
  width: 100%;
  height: 100%;
}

.photo-remove {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 46rpx;
  line-height: 46rpx;
  border-radius: 0;
  background: rgba(139, 63, 52, 0.86);
  color: #ffffff;
  font-size: 22rpx;
}

.legal-card {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.legal-check {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #4d443f;
  font-size: 24rpx;
}

.legal-links {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legal-link {
  display: inline-flex;
  width: auto;
  height: auto;
  line-height: 1.4;
  padding: 0;
  background: transparent;
  color: #9e4238;
  font-size: 24rpx;
}

.bottom-actions {
  position: sticky;
  bottom: 24rpx;
  padding-top: 10rpx;
}

.bottom-actions .btn {
  flex: 1;
}
