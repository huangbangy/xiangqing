.me-main {
  flex: 1;
  min-width: 0;
}

.me-name {
  font-family: "Songti SC", "Noto Serif SC", serif;
  font-size: 40rpx;
  font-weight: 700;
  color: #2b2522;
  margin-bottom: 8rpx;
  line-height: 1.2;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.mode-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.mode-card {
  min-height: 136rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.66);
  border: 1rpx solid rgba(139, 63, 52, 0.1);
  color: #4d443f;
  text-align: left;
  line-height: 1.45;
  box-sizing: border-box;
}

.mode-card-active {
  background: #2b2522;
  color: #fff8f3;
  border-color: rgba(43, 37, 34, 0.9);
  box-shadow: 0 16rpx 34rpx rgba(43, 37, 34, 0.16);
}

.mode-title {
  font-size: 28rpx;
  font-weight: 700;
}

.mode-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: 0.82;
}

.mode-note {
  margin-top: 14rpx;
  line-height: 1.55;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.stat-card {
  text-align: left;
  padding: 24rpx 20rpx;
  background: rgba(255, 255, 255, 0.68);
}

.stat-number {
  font-family: "Songti SC", "Noto Serif SC", serif;
  font-size: 42rpx;
  font-weight: 700;
  color: #d95b4f;
  line-height: 1.1;
}

.completion-card {
  background:
    linear-gradient(145deg, rgba(255, 253, 249, 0.94) 0%, rgba(247, 250, 243, 0.9) 100%);
}

.completion-score {
  flex: 0 0 auto;
  font-family: "Songti SC", "Noto Serif SC", serif;
  font-size: 44rpx;
  font-weight: 700;
  color: #d95b4f;
}

.completion-track {
  margin-top: 18rpx;
}

.completion-missing {
  margin-top: 12rpx;
  color: #8b3f34;
  font-size: 24rpx;
  line-height: 1.5;
}

.action-list {
  padding: 0;
  overflow: hidden;
}

.action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  min-height: 98rpx;
  line-height: 1.25;
  padding: 0 26rpx;
  border-radius: 0;
  background: rgba(255, 255, 255, 0.62);
  color: #2b2522;
  font-size: 28rpx;
  text-align: left;
  box-sizing: border-box;
}

.action-row + .action-row {
  border-top: 1rpx solid rgba(139, 63, 52, 0.1);
}

.action-row-strong {
  background: rgba(217, 91, 79, 0.1);
  color: #9e4238;
  font-weight: 700;
}

.recent-empty {
  padding: 24rpx 0 8rpx;
}

.recent-list {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
  margin-top: 18rpx;
}

.recent-card {
  padding: 18rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.64);
  border: 1rpx solid rgba(139, 63, 52, 0.1);
}

.recent-avatar {
  width: 82rpx;
  height: 82rpx;
  font-size: 26rpx;
}

.recent-main {
  flex: 1;
  min-width: 0;
}

.recent-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #8b3f34;
  margin-bottom: 4rpx;
}

.recent-bio {
  margin-top: 8rpx;
  color: #4d443f;
  line-height: 1.5;
  font-size: 24rpx;
}

.cloud-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12rpx;
}
