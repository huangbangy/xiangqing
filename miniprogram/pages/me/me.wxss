.me-main {
  flex: 1;
  min-width: 0;
}

.me-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 8rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.mode-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.mode-card {
  min-height: 128rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: #fff7f7;
  color: #7f1d1d;
  text-align: left;
  line-height: 1.4;
  box-sizing: border-box;
}

.mode-card-active {
  background: #ffe4e6;
  color: #b5362b;
  border: 1rpx solid #fda4af;
}

.mode-title {
  font-size: 28rpx;
  font-weight: 700;
}

.mode-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
}

.mode-note {
  margin-top: 14rpx;
  line-height: 1.5;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.stat-card {
  text-align: center;
  padding: 20rpx 8rpx;
}

.stat-number {
  font-size: 36rpx;
  font-weight: 700;
  color: #c63d2f;
}

.completion-card {
  background: #fffafa;
}

.completion-score {
  flex: 0 0 auto;
  font-size: 40rpx;
  font-weight: 700;
  color: #c63d2f;
}

.completion-track {
  margin-top: 18rpx;
}

.completion-missing {
  margin-top: 12rpx;
  color: #7f1d1d;
  font-size: 24rpx;
  line-height: 1.45;
}

.action-list {
  padding: 0;
  overflow: hidden;
}

.action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 96rpx;
  line-height: 1;
  padding: 0 24rpx;
  border-radius: 0;
  background: #ffffff;
  color: #0f172a;
  font-size: 28rpx;
  text-align: left;
  box-sizing: border-box;
}

.action-row + .action-row {
  border-top: 1rpx solid #f3d0d4;
}

.recent-empty {
  padding: 24rpx 0 8rpx;
}

.recent-list {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
  margin-top: 18rpx;
}

.recent-card {
  padding: 16rpx;
  border-radius: 8rpx;
  background: #fff7f7;
  border: 1rpx solid #f7d8d1;
}

.recent-avatar {
  width: 80rpx;
  height: 80rpx;
  font-size: 26rpx;
}

.recent-main {
  flex: 1;
  min-width: 0;
}

.recent-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #8f271d;
  margin-bottom: 4rpx;
}

.recent-bio {
  margin-top: 8rpx;
  color: #6b2b23;
  line-height: 1.45;
  font-size: 24rpx;
}

.cloud-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12rpx;
}
