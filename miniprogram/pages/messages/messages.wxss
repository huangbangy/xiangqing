.messages-head {
  align-items: flex-start;
}

.message-card {
  background: #fffafa;
}

.message-main {
  flex: 1;
  min-width: 0;
}

.message-top {
  align-items: flex-start;
  gap: 16rpx;
}

.message-title-wrap {
  flex: 1;
  min-width: 0;
}

.message-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 6rpx;
}

.message-meta {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.message-time {
  font-size: 22rpx;
  color: #94a3b8;
}

.unread-dot {
  min-width: 34rpx;
  height: 34rpx;
  line-height: 34rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  border-radius: 17rpx;
  background: #c63d2f;
  color: #ffffff;
  font-size: 20rpx;
  text-align: center;
}

.message-last {
  margin-top: 14rpx;
  color: #334155;
  line-height: 1.55;
}

.message-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.tag-warm {
  background: #fff7ed;
  color: #c2410c;
}

.message-actions {
  gap: 16rpx;
  margin-top: 20rpx;
}

.message-actions .btn {
  flex: 1;
}

.empty-action {
  margin-top: 24rpx;
}
