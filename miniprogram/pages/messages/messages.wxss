.messages-head {
  align-items: flex-start;
  padding: 8rpx 2rpx 0;
}

.message-card {
  background: rgba(255, 255, 255, 0.74);
}

.message-main {
  flex: 1;
  min-width: 0;
}

.message-top {
  align-items: flex-start;
  gap: 16rpx;
}

.message-title-wrap {
  flex: 1;
  min-width: 0;
}

.message-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #2b2522;
  margin-bottom: 6rpx;
}

.message-meta {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.message-time {
  font-size: 22rpx;
  color: #a0968e;
}

.unread-dot {
  min-width: 34rpx;
  height: 34rpx;
  line-height: 34rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: #d95b4f;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  text-align: center;
  box-shadow: 0 8rpx 18rpx rgba(217, 91, 79, 0.24);
}

.message-last {
  margin-top: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(126, 156, 134, 0.09);
  color: #4d443f;
  line-height: 1.55;
}

.message-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.tag-warm {
  background: rgba(242, 216, 167, 0.3);
  color: #73591f;
}

.message-actions {
  gap: 16rpx;
  margin-top: 20rpx;
}

.message-actions .btn {
  flex: 1;
}

.empty-action {
  margin-top: 24rpx;
}
