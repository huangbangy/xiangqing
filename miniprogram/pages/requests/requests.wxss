.request-overview {
  margin-top: 4rpx;
}

.request-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin: 22rpx 0 18rpx;
}

.request-stat {
  padding: 16rpx 8rpx;
  border-radius: 8rpx;
  background: #f9f1ed;
  text-align: center;
}

.request-stat-number {
  font-size: 34rpx;
  font-weight: 700;
  color: #b83a2f;
  line-height: 1.1;
}

.request-safety {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 8rpx;
  background: #f2ead9;
  color: #7c5a16;
  font-size: 24rpx;
  line-height: 1.5;
}

.request-main {
  flex: 1;
  min-width: 0;
}

.request-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #241d1a;
  margin-bottom: 6rpx;
}

.request-badges {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.request-channel {
  background: #f9e7e3;
  color: #a53128;
}

.request-message {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  background: #f9f1ed;
  color: #51443f;
  line-height: 1.55;
}

.message-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
  color: #33211d;
  font-weight: 700;
}

.message-quality {
  flex: 0 0 auto;
  padding: 0 12rpx;
  height: 36rpx;
  line-height: 36rpx;
  border-radius: 18rpx;
  font-size: 20rpx;
  font-weight: 400;
}

.message-quality-good {
  background: #edf7ed;
  color: #256d35;
}

.message-quality-soft {
  background: #f5ebe6;
  color: #6f332c;
}

.message-quality-warn {
  background: #f2ead9;
  color: #7c5a16;
}

.request-status-hint {
  margin-top: 12rpx;
  color: #746862;
  font-size: 24rpx;
  line-height: 1.45;
}

.request-contact {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  background: #f9e7e3;
  color: #a53128;
  line-height: 1.6;
  font-size: 24rpx;
}

.request-actions {
  margin-top: 20rpx;
}
