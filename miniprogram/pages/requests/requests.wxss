.request-main {
  flex: 1;
  min-width: 0;
}

.request-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #2b2522;
  margin-bottom: 6rpx;
}

.request-badges {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.request-channel {
  background: rgba(217, 91, 79, 0.1);
  color: #9e4238;
}

.request-message {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(126, 156, 134, 0.09);
  color: #4d443f;
  line-height: 1.55;
}

.request-contact {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: rgba(217, 91, 79, 0.1);
  color: #8b3f34;
  line-height: 1.6;
  font-size: 24rpx;
}

.request-actions {
  gap: 14rpx;
  margin-top: 20rpx;
}

.request-actions .btn {
  flex: 1;
}
