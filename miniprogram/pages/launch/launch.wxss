.launch-hero {
  margin-top: 4rpx;
}

.launch-summary {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin: 22rpx 0 14rpx;
}

.summary-pill {
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 8rpx;
  text-align: center;
  font-size: 24rpx;
}

.summary-pass {
  background: #edf7ed;
  color: #256d35;
}

.summary-warn {
  background: #f2ead9;
  color: #7c5a16;
}

.summary-fail {
  background: #f9e7e3;
  color: #a53128;
}

.check-list,
.guide-list,
.manual-list {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
}

.section-subtitle {
  margin-top: -4rpx;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.check-card {
  padding: 18rpx;
  border-radius: 8rpx;
  background: #f9f1ed;
  border: 1rpx solid rgba(145, 65, 54, 0.1);
}

.check-pass {
  background: #f4f8f1;
}

.check-warn {
  background: #f8f2e6;
}

.check-fail {
  background: #f9e7e3;
}

.check-head {
  gap: 16rpx;
}

.check-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #33211d;
}

.check-status {
  flex: 0 0 auto;
  padding: 0 14rpx;
  height: 40rpx;
  line-height: 40rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #6f332c;
  font-size: 22rpx;
}

.check-desc {
  margin-top: 10rpx;
  color: #51443f;
  line-height: 1.5;
  font-size: 24rpx;
}

.check-detail {
  margin-top: 8rpx;
  color: #746862;
  line-height: 1.45;
  font-size: 22rpx;
}

.manual-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  color: #51443f;
  line-height: 1.55;
}

.manual-dot {
  flex: 0 0 auto;
  width: 12rpx;
  height: 12rpx;
  margin-top: 14rpx;
  border-radius: 50%;
  background: #b83a2f;
}

.guide-head {
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.guide-item {
  padding: 18rpx;
  border-radius: 8rpx;
  background: #f9f1ed;
}

.guide-title {
  color: #33211d;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.guide-text {
  color: #51443f;
  line-height: 1.6;
  font-size: 24rpx;
}

.screenshot-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12rpx;
}

.screenshot-item {
  display: grid;
  grid-template-columns: 48rpx 1fr;
  align-items: flex-start;
  gap: 14rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  background: #f9f1ed;
  color: #51443f;
  line-height: 1.5;
}

.screenshot-index {
  height: 42rpx;
  line-height: 42rpx;
  border-radius: 21rpx;
  text-align: center;
  background: #b83a2f;
  color: #ffffff;
  font-size: 22rpx;
}

.rule-row {
  display: grid;
  grid-template-columns: 88rpx 1fr;
  gap: 14rpx;
  padding: 16rpx 0;
  color: #51443f;
  line-height: 1.55;
  border-top: 1rpx solid rgba(145, 65, 54, 0.1);
}

.rule-row:first-of-type {
  border-top: none;
}

.rule-label {
  height: 42rpx;
  line-height: 42rpx;
  border-radius: 21rpx;
  text-align: center;
  background: #edf7ed;
  color: #256d35;
  font-size: 22rpx;
}

.rule-warn {
  background: #f2ead9;
  color: #7c5a16;
}

.rule-danger {
  background: #f9e7e3;
  color: #a53128;
}
