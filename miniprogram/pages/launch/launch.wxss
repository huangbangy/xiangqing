.launch-hero {
  margin-top: 2rpx;
  background:
    linear-gradient(145deg, rgba(255, 253, 249, 0.94) 0%, rgba(247, 250, 243, 0.9) 100%);
}

.launch-summary {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin: 22rpx 0 14rpx;
}

.summary-pill {
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
}

.summary-pass {
  background: rgba(126, 156, 134, 0.13);
  color: #496c52;
}

.summary-warn {
  background: rgba(242, 216, 167, 0.3);
  color: #73591f;
}

.summary-fail {
  background: rgba(217, 91, 79, 0.1);
  color: #9e4238;
}

.check-list,
.guide-list,
.manual-list {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
}

.section-subtitle {
  margin-top: -4rpx;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.check-card {
  padding: 20rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.64);
  border: 1rpx solid rgba(139, 63, 52, 0.1);
}

.check-pass {
  background: rgba(126, 156, 134, 0.1);
}

.check-warn {
  background: rgba(242, 216, 167, 0.24);
}

.check-fail {
  background: rgba(217, 91, 79, 0.1);
}

.check-head {
  gap: 16rpx;
}

.check-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2b2522;
}

.check-status {
  flex: 0 0 auto;
  padding: 0 14rpx;
  height: 42rpx;
  line-height: 42rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #72564d;
  font-size: 22rpx;
}

.check-desc {
  margin-top: 10rpx;
  color: #4d443f;
  line-height: 1.5;
  font-size: 24rpx;
}

.check-detail {
  margin-top: 8rpx;
  color: #766b63;
  line-height: 1.45;
  font-size: 22rpx;
}

.manual-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  color: #4d443f;
  line-height: 1.55;
}

.manual-dot {
  flex: 0 0 auto;
  width: 12rpx;
  height: 12rpx;
  margin-top: 14rpx;
  border-radius: 50%;
  background: #d95b4f;
  box-shadow: 0 0 0 8rpx rgba(217, 91, 79, 0.08);
}

.guide-head {
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.guide-item {
  padding: 20rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.64);
  border: 1rpx solid rgba(139, 63, 52, 0.08);
}

.guide-title {
  color: #2b2522;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.guide-text {
  color: #4d443f;
  line-height: 1.6;
  font-size: 24rpx;
}

.screenshot-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12rpx;
}

.screenshot-item {
  display: grid;
  grid-template-columns: 48rpx 1fr;
  align-items: flex-start;
  gap: 14rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.64);
  color: #4d443f;
  line-height: 1.5;
}

.screenshot-index {
  height: 42rpx;
  line-height: 42rpx;
  border-radius: 999rpx;
  text-align: center;
  background: #2b2522;
  color: #fff8f3;
  font-size: 22rpx;
}

.rule-row {
  display: grid;
  grid-template-columns: 88rpx 1fr;
  gap: 14rpx;
  padding: 16rpx 0;
  color: #4d443f;
  line-height: 1.55;
  border-top: 1rpx solid rgba(139, 63, 52, 0.1);
}

.rule-row:first-of-type {
  border-top: none;
}

.rule-label {
  height: 42rpx;
  line-height: 42rpx;
  border-radius: 999rpx;
  text-align: center;
  background: rgba(126, 156, 134, 0.13);
  color: #496c52;
  font-size: 22rpx;
}

.rule-warn {
  background: rgba(242, 216, 167, 0.3);
  color: #73591f;
}

.rule-danger {
  background: rgba(217, 91, 79, 0.1);
  color: #9e4238;
}
