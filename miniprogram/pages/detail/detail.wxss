.detail-header {
  margin-top: 4rpx;
}

.detail-main {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #241d1a;
  margin-bottom: 8rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.trust-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.trust-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-height: 64rpx;
  padding: 0 16rpx;
  border-radius: 8rpx;
  background: #f9f1ed;
  color: #6f332c;
  font-size: 24rpx;
  box-sizing: border-box;
}

.trust-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #b83a2f;
}

.trust-item-primary {
  background: #f9e7e3;
  color: #a53128;
}

.trust-item-warm {
  background: #f2ead9;
  color: #7c5a16;
}

.trust-item-soft {
  background: #f5ebe6;
  color: #6f332c;
}

.paragraph {
  color: #51443f;
  line-height: 1.7;
}

.intro-list {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
}

.intro-item {
  padding: 18rpx;
  border-radius: 8rpx;
  background: #f9f1ed;
  border-left: 6rpx solid #b83a2f;
}

.intro-label {
  color: #a53128;
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.intro-text {
  color: #33211d;
  line-height: 1.6;
}

.lifestyle-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.tag-warm {
  background: #f2ead9;
  color: #7c5a16;
}

.tag-mode {
  background: #f9e7e3;
  color: #a53128;
}

.match-card-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.match-answer-card {
  min-height: 96rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  background: #f9f1ed;
  border: 1rpx solid rgba(145, 65, 54, 0.12);
  box-sizing: border-box;
}

.match-answer-label {
  color: #a53128;
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.match-answer-value {
  color: #33211d;
  font-size: 28rpx;
  font-weight: 600;
}

.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.contact-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.contact-note {
  margin-top: 18rpx;
}

.locked-contact {
  padding: 24rpx;
  border-radius: 8rpx;
  background: #f9f1ed;
  color: #6f332c;
  line-height: 1.6;
}

.chat-ready {
  padding: 22rpx;
  border-radius: 8rpx;
  background: #f9f1ed;
  color: #6f332c;
  line-height: 1.6;
}

.template-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.template-chip {
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 26rpx;
  background: #f5ebe6;
  color: #6f332c;
  font-size: 24rpx;
}

.action-row {
  gap: 16rpx;
  margin-top: 18rpx;
}

.action-row .btn {
  flex: 1;
}

.report-btn {
  margin-top: 12rpx;
}
