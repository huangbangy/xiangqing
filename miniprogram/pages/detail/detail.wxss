.detail-page {
  padding-top: 22rpx;
}

.detail-header {
  margin-top: 2rpx;
  padding: 32rpx;
  background:
    linear-gradient(135deg, rgba(43, 37, 34, 0.96) 0%, rgba(139, 63, 52, 0.94) 100%);
  border-color: rgba(255, 248, 243, 0.2);
  color: #fff8f3;
  box-shadow: 0 22rpx 52rpx rgba(80, 52, 46, 0.18);
}

.detail-header .avatar {
  border: 3rpx solid rgba(255, 248, 243, 0.72);
}

.detail-header .subtle {
  color: rgba(255, 248, 243, 0.72);
}

.detail-main {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-family: "Songti SC", "Noto Serif SC", serif;
  font-size: 42rpx;
  font-weight: 700;
  color: #fff8f3;
  margin-bottom: 8rpx;
  line-height: 1.18;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.detail-header .tag {
  background: rgba(255, 248, 243, 0.14);
  color: #fff8f3;
  border: 1rpx solid rgba(255, 248, 243, 0.18);
}

.detail-header .tag-soft {
  background: rgba(242, 216, 167, 0.18);
  color: #f8e1b7;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-height: 104rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.62);
  border: 1rpx solid rgba(139, 63, 52, 0.08);
  box-sizing: border-box;
  color: #2b2522;
}

.trust-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.trust-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-height: 68rpx;
  padding: 0 16rpx;
  border-radius: 16rpx;
  background: rgba(126, 156, 134, 0.11);
  color: #496c52;
  font-size: 24rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.trust-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #7e9c86;
  box-shadow: 0 0 0 8rpx rgba(126, 156, 134, 0.1);
}

.trust-item-primary {
  background: rgba(43, 37, 34, 0.92);
  color: #fff8f3;
}

.trust-item-primary .trust-dot {
  background: #f2d8a7;
}

.trust-item-warm {
  background: rgba(242, 216, 167, 0.3);
  color: #73591f;
}

.trust-item-soft {
  background: rgba(217, 91, 79, 0.1);
  color: #9e4238;
}

.paragraph {
  color: #4d443f;
  line-height: 1.75;
}

.intro-list {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
}

.intro-item {
  position: relative;
  padding: 20rpx 20rpx 20rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.62);
  border: 1rpx solid rgba(139, 63, 52, 0.08);
}

.intro-item::before {
  content: "";
  position: absolute;
  left: 0;
  top: 20rpx;
  bottom: 20rpx;
  width: 6rpx;
  border-radius: 0 999rpx 999rpx 0;
  background: #d95b4f;
}

.intro-label {
  color: #9e4238;
  font-size: 22rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.intro-text {
  color: #2b2522;
  line-height: 1.65;
}

.lifestyle-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.tag-warm {
  background: rgba(242, 216, 167, 0.3);
  color: #73591f;
}

.tag-mode {
  background: rgba(126, 156, 134, 0.13);
  color: #496c52;
}

.match-card-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.match-answer-card {
  min-height: 104rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.64);
  border: 1rpx solid rgba(139, 63, 52, 0.1);
  box-sizing: border-box;
}

.match-answer-label {
  color: #8c7d72;
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.match-answer-value {
  color: #2b2522;
  font-size: 28rpx;
  font-weight: 700;
}

.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.contact-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.62);
  border: 1rpx solid rgba(139, 63, 52, 0.08);
}

.contact-note {
  margin-top: 18rpx;
}

.locked-contact {
  padding: 24rpx;
  border-radius: 16rpx;
  background: rgba(126, 156, 134, 0.1);
  color: #496c52;
  line-height: 1.65;
}

.chat-ready {
  padding: 24rpx;
  border-radius: 16rpx;
  background: rgba(126, 156, 134, 0.1);
  color: #496c52;
  line-height: 1.65;
}

.template-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.contact-checklist {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.check-item {
  height: 44rpx;
  line-height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(126, 156, 134, 0.11);
  color: #496c52;
  font-size: 22rpx;
}

.template-chip {
  height: 54rpx;
  line-height: 54rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.68);
  border: 1rpx solid rgba(139, 63, 52, 0.12);
  color: #8b3f34;
  font-size: 24rpx;
}

.template-chip-safe {
  background: rgba(217, 91, 79, 0.1);
  color: #9e4238;
}

.action-row {
  gap: 16rpx;
  margin-top: 18rpx;
}

.action-row .btn {
  flex: 1;
}

.report-btn {
  margin-top: 12rpx;
}
