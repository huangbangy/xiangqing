.chat-page {
  padding-bottom: 246rpx;
}

.chat-profile {
  margin-bottom: 18rpx;
}

.chat-profile-main {
  flex: 1;
  min-width: 0;
}

.chat-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #241d1a;
  margin-bottom: 6rpx;
}

.profile-btn {
  margin-top: 18rpx;
}

.chat-scroll {
  height: calc(100vh - 430rpx);
  min-height: 520rpx;
  box-sizing: border-box;
}

.safety-tip {
  margin-bottom: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 8rpx;
  background: #f2ead9;
  color: #7c5a16;
  font-size: 24rpx;
  line-height: 1.55;
}

.message-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.message-row-mine {
  justify-content: flex-end;
}

.message-row-system {
  justify-content: center;
}

.chat-avatar {
  width: 72rpx;
  height: 72rpx;
  font-size: 24rpx;
}

.bubble-wrap {
  max-width: 74%;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.message-row-mine .bubble-wrap {
  align-items: flex-end;
}

.message-time {
  margin-bottom: 8rpx;
  color: #94a3b8;
  font-size: 20rpx;
}

.message-bubble {
  padding: 18rpx 20rpx;
  border-radius: 8rpx;
  background: #fffdfb;
  border: 1rpx solid rgba(145, 65, 54, 0.12);
  color: #33211d;
  line-height: 1.55;
  word-break: break-all;
  box-shadow: 0 8rpx 20rpx rgba(72, 42, 36, 0.06);
}

.message-row-mine .message-bubble {
  background: #b83a2f;
  border-color: #b83a2f;
  color: #ffffff;
}

.system-message {
  max-width: 82%;
  padding: 12rpx 18rpx;
  border-radius: 8rpx;
  background: rgba(184, 58, 47, 0.08);
  color: #6f332c;
  font-size: 22rpx;
  line-height: 1.5;
  text-align: center;
}

.chat-composer-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  padding: 16rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: rgba(255, 253, 251, 0.98);
  border-top: 1rpx solid rgba(145, 65, 54, 0.12);
}

.quick-replies {
  display: flex;
  gap: 10rpx;
  overflow-x: auto;
  white-space: nowrap;
  margin-bottom: 14rpx;
}

.quick-chip {
  flex: 0 0 auto;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 26rpx;
  background: #f5ebe6;
  color: #6f332c;
  font-size: 24rpx;
}

.composer-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.chat-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(145, 65, 54, 0.16);
  border-radius: 8rpx;
  background: #fffdfb;
  color: #33211d;
  font-size: 28rpx;
}

.send-btn {
  width: 128rpx;
  padding: 0;
}
