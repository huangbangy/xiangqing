.chat-page {
  padding-bottom: 248rpx;
}

.chat-profile {
  margin-bottom: 18rpx;
  background:
    linear-gradient(145deg, rgba(255, 253, 249, 0.94) 0%, rgba(247, 250, 243, 0.9) 100%);
}

.chat-profile-main {
  flex: 1;
  min-width: 0;
}

.chat-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #2b2522;
  margin-bottom: 6rpx;
}

.profile-btn {
  margin-top: 18rpx;
}

.chat-scroll {
  height: calc(100vh - 430rpx);
  min-height: 520rpx;
  box-sizing: border-box;
}

.safety-tip {
  margin-bottom: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: rgba(242, 216, 167, 0.28);
  color: #73591f;
  font-size: 24rpx;
  line-height: 1.55;
}

.message-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.message-row-mine {
  justify-content: flex-end;
}

.message-row-system {
  justify-content: center;
}

.chat-avatar {
  width: 72rpx;
  height: 72rpx;
  font-size: 24rpx;
}

.bubble-wrap {
  max-width: 74%;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.message-row-mine .bubble-wrap {
  align-items: flex-end;
}

.message-time {
  margin-bottom: 8rpx;
  color: #a0968e;
  font-size: 20rpx;
}

.message-bubble {
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(139, 63, 52, 0.1);
  color: #2b2522;
  line-height: 1.55;
  word-break: break-all;
  box-shadow: 0 10rpx 24rpx rgba(80, 52, 46, 0.08);
}

.message-row-mine .message-bubble {
  background: #2b2522;
  border-color: #2b2522;
  color: #fff8f3;
  box-shadow: 0 14rpx 30rpx rgba(43, 37, 34, 0.18);
}

.system-message {
  max-width: 82%;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(126, 156, 134, 0.12);
  color: #496c52;
  font-size: 22rpx;
  line-height: 1.5;
  text-align: center;
}

.chat-composer-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  padding: 16rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: rgba(255, 248, 243, 0.9);
  border-top: 1rpx solid rgba(139, 63, 52, 0.12);
  box-shadow: 0 -18rpx 40rpx rgba(80, 52, 46, 0.08);
  -webkit-backdrop-filter: blur(18rpx);
  backdrop-filter: blur(18rpx);
}

.quick-replies {
  display: flex;
  gap: 10rpx;
  overflow-x: auto;
  white-space: nowrap;
  margin-bottom: 14rpx;
}

.quick-chip {
  flex: 0 0 auto;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(139, 63, 52, 0.1);
  color: #8b3f34;
  font-size: 24rpx;
}

.composer-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.chat-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(139, 63, 52, 0.14);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #2b2522;
  font-size: 28rpx;
}

.send-btn {
  width: 132rpx;
  padding: 0;
}
