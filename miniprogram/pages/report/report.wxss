.report-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #7f1d1d;
  margin-bottom: 6rpx;
}

.evidence-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 16rpx;
}

.evidence-item {
  position: relative;
  aspect-ratio: 1 / 1;
  border-radius: 8rpx;
  overflow: hidden;
  background: #fff1f2;
}

.evidence-item image {
  width: 100%;
  height: 100%;
}

.evidence-remove {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 44rpx;
  line-height: 44rpx;
  border-radius: 0;
  background: rgba(185, 28, 28, 0.78);
  color: #ffffff;
  font-size: 22rpx;
}
