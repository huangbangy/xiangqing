.report-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #8b3f34;
  margin-bottom: 6rpx;
}

.evidence-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 16rpx;
}

.upload-bar {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(217, 91, 79, 0.1);
  color: #9e4238;
  font-size: 24rpx;
}

.evidence-item {
  position: relative;
  aspect-ratio: 1 / 1;
  border-radius: 16rpx;
  overflow: hidden;
  background: rgba(217, 91, 79, 0.08);
  border: 1rpx solid rgba(139, 63, 52, 0.08);
}

.evidence-item image {
  width: 100%;
  height: 100%;
}

.evidence-remove {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 46rpx;
  line-height: 46rpx;
  border-radius: 0;
  background: rgba(139, 63, 52, 0.86);
  color: #ffffff;
  font-size: 22rpx;
}
