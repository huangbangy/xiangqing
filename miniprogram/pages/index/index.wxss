.top-panel {
  margin-top: 4rpx;
  background: #fffafa;
}

.top-hero {
  align-items: flex-start;
  gap: 16rpx;
}

.festival-hero {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.festival-mark-wrap {
  flex: 0 0 auto;
  width: 124rpx;
  height: 124rpx;
  border-radius: 22rpx;
  background: #fff1f2;
  border: 1rpx solid #fecdd3;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(185, 28, 28, 0.08);
}

.festival-mark {
  font-size: 92rpx;
  line-height: 1;
  color: #c63d2f;
  font-weight: 700;
  font-family: KaiTi, STKaiti, serif;
}

.festival-copy {
  flex: 1;
  min-width: 0;
}

.index-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.2;
}

.hero-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.soft-chip {
  display: inline-flex;
  align-items: center;
  height: 46rpx;
  line-height: 46rpx;
  padding: 0 16rpx;
  border-radius: 23rpx;
  background: #fff1f2;
  color: #b5362b;
  font-size: 22rpx;
}

.soft-chip-warm {
  background: #fff7ed;
  color: #c2410c;
}

.soft-chip-mode {
  background: #ffe4e6;
  color: #9f1239;
}

.festival-sub {
  margin-top: 10rpx;
  color: #991b1b;
  font-size: 24rpx;
  line-height: 1.45;
}

.hero-stat {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 22rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: #fff1f2;
}

.hero-stat-number {
  font-size: 42rpx;
  font-weight: 700;
  color: #c63d2f;
  line-height: 1;
}

.hero-stat-copy {
  flex: 1;
  color: #334155;
  font-size: 24rpx;
  line-height: 1.5;
  text-align: right;
}

.search-row {
  display: grid;
  grid-template-columns: 1fr auto auto;
  gap: 12rpx;
  margin-top: 24rpx;
  align-items: center;
}

.search-input {
  height: 72rpx;
}

.filter-line {
  margin-top: 18rpx;
}

.profile-card {
  position: relative;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.profile-head {
  align-items: flex-start;
}

.badge-stack {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.publisher-badge {
  padding: 0 12rpx;
  height: 38rpx;
  line-height: 38rpx;
  border-radius: 19rpx;
  background: #fff1f2;
  color: #b5362b;
  font-size: 20rpx;
}

.profile-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
}

.profile-meta {
  display: block;
  margin-top: 4rpx;
  color: #64748b;
  font-size: 24rpx;
}

.profile-summary {
  margin-top: 12rpx;
}

.profile-intro {
  margin-top: 10rpx;
  color: #334155;
  line-height: 1.55;
  padding: 14rpx 16rpx;
  border-radius: 8rpx;
  background: #fff7f7;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.lifestyle-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.trust-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.trust-badge {
  display: inline-flex;
  align-items: center;
  height: 42rpx;
  line-height: 42rpx;
  padding: 0 14rpx;
  border-radius: 21rpx;
  font-size: 22rpx;
  background: #fff1f2;
  color: #7f1d1d;
}

.trust-badge-primary {
  background: #c63d2f;
  color: #ffffff;
}

.trust-badge-warm {
  background: #fff7ed;
  color: #c2410c;
}

.trust-badge-soft {
  background: #fff1f2;
  color: #b5362b;
}

.tag-warm {
  background: #fff7ed;
  color: #c2410c;
}

.recommend-panel {
  background: #fffafa;
}

.recommend-head {
  align-items: flex-start;
  gap: 16rpx;
}

.recommend-tools {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.recommend-tool {
  height: 46rpx;
  line-height: 46rpx;
  padding: 0 16rpx;
  border-radius: 23rpx;
  background: #fff1f2;
  color: #b5362b;
  font-size: 22rpx;
}

.recommend-tool-muted {
  background: #fff7ed;
  color: #c2410c;
}

.recommend-count {
  flex: 0 0 auto;
  height: 46rpx;
  line-height: 46rpx;
  padding: 0 16rpx;
  border-radius: 23rpx;
  background: #ffe4e6;
  color: #b5362b;
  font-size: 22rpx;
}

.recommend-list {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
  margin-top: 18rpx;
}

.recommend-empty {
  margin-top: 18rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  background: #fff7f7;
  color: #7f1d1d;
  text-align: center;
  line-height: 1.6;
}

.recommend-empty-action {
  margin-top: 18rpx;
}

.recommend-card {
  padding: 18rpx;
  border-radius: 8rpx;
  background: #ffffff;
  border: 1rpx solid #f8cdd2;
}

.avatar-recommend {
  width: 88rpx;
  height: 88rpx;
  font-size: 28rpx;
}

.recommend-main {
  flex: 1;
  min-width: 0;
}

.recommend-top {
  align-items: flex-start;
  gap: 14rpx;
}

.recommend-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #7f1d1d;
  margin-bottom: 4rpx;
}

.recommend-score {
  flex: 0 0 auto;
  height: 42rpx;
  line-height: 42rpx;
  padding: 0 14rpx;
  border-radius: 21rpx;
  background: #c63d2f;
  color: #ffffff;
  font-size: 22rpx;
}

.recommend-reason {
  margin-top: 12rpx;
  color: #7f1d1d;
  font-size: 24rpx;
  line-height: 1.45;
}

.recommend-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.recommend-actions {
  gap: 10rpx;
  margin-top: 18rpx;
}

.recommend-actions .btn {
  flex: 1;
  padding: 0 12rpx;
}

.card-actions {
  margin-top: 22rpx;
}

.empty-action {
  margin-top: 24rpx;
}
