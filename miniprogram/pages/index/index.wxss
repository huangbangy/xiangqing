.index-page {
  padding-top: 22rpx;
}

.top-panel {
  margin-top: 2rpx;
  position: relative;
  overflow: hidden;
  padding: 32rpx;
  background:
    linear-gradient(136deg, rgba(255, 253, 249, 0.95) 0%, rgba(247, 250, 243, 0.9) 58%, rgba(250, 231, 226, 0.92) 100%);
  border-color: rgba(139, 63, 52, 0.14);
}

.top-panel::after {
  content: "MATCH";
  position: absolute;
  right: -18rpx;
  top: 18rpx;
  color: rgba(43, 37, 34, 0.035);
  font-family: "Songti SC", "Noto Serif SC", serif;
  font-size: 108rpx;
  font-weight: 700;
  line-height: 1;
  transform: rotate(8deg);
}

.top-hero {
  position: relative;
  z-index: 1;
  align-items: flex-start;
  gap: 18rpx;
}

.festival-hero {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  flex: 1;
  min-width: 0;
}

.festival-mark-wrap {
  flex: 0 0 auto;
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  background:
    linear-gradient(145deg, #2b2522 0%, #8b3f34 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 34rpx rgba(139, 63, 52, 0.25);
}

.festival-mark {
  font-size: 62rpx;
  line-height: 1;
  color: #fff8f3;
  font-weight: 700;
  font-family: "Songti SC", "Noto Serif SC", serif;
}

.festival-copy {
  flex: 1;
  min-width: 0;
}

.index-title {
  font-family: "Songti SC", "Noto Serif SC", serif;
  font-size: 46rpx;
  font-weight: 700;
  color: #2b2522;
  line-height: 1.18;
  letter-spacing: 0;
}

.hero-chips {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 24rpx;
}

.soft-chip {
  display: inline-flex;
  align-items: center;
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(139, 63, 52, 0.1);
  color: #72564d;
  font-size: 22rpx;
  font-weight: 600;
}

.soft-chip-warm {
  background: rgba(242, 216, 167, 0.28);
  color: #73591f;
}

.soft-chip-mode {
  background: rgba(217, 91, 79, 0.1);
  color: #9e4238;
}

.festival-sub {
  margin-top: 10rpx;
  color: #6d625b;
  font-size: 24rpx;
  line-height: 1.55;
}

.hero-stat {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.66);
  border: 1rpx solid rgba(139, 63, 52, 0.1);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.82);
}

.hero-stat-number {
  font-family: "Songti SC", "Noto Serif SC", serif;
  font-size: 50rpx;
  font-weight: 700;
  color: #d95b4f;
  line-height: 1;
}

.hero-stat-copy {
  flex: 1;
  color: #4d443f;
  font-size: 24rpx;
  line-height: 1.55;
  text-align: right;
}

.search-row {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1fr auto auto;
  gap: 12rpx;
  margin-top: 24rpx;
  align-items: center;
}

.search-input {
  height: 76rpx;
}

.filter-line {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
}

.recommend-panel {
  background:
    linear-gradient(145deg, rgba(255, 253, 249, 0.94) 0%, rgba(248, 252, 246, 0.9) 100%);
}

.recommend-head {
  align-items: flex-start;
  gap: 16rpx;
}

.recommend-tools {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.recommend-tool {
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(139, 63, 52, 0.12);
  color: #8b3f34;
  font-size: 22rpx;
  font-weight: 600;
}

.recommend-tool-muted {
  background: rgba(242, 216, 167, 0.25);
  color: #73591f;
}

.recommend-count {
  flex: 0 0 auto;
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #2b2522;
  color: #fff8f3;
  font-size: 22rpx;
}

.recommend-list {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
  margin-top: 20rpx;
}

.recommend-empty {
  margin-top: 18rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  background: rgba(126, 156, 134, 0.1);
  color: #496c52;
  text-align: center;
  line-height: 1.65;
}

.recommend-empty-action {
  margin-top: 18rpx;
}

.recommend-card {
  position: relative;
  padding: 22rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.68);
  border: 1rpx solid rgba(139, 63, 52, 0.12);
  box-shadow: 0 14rpx 34rpx rgba(80, 52, 46, 0.08);
}

.recommend-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 24rpx;
  width: 6rpx;
  height: 74rpx;
  border-radius: 0 999rpx 999rpx 0;
  background: #7e9c86;
}

.avatar-recommend {
  width: 88rpx;
  height: 88rpx;
  font-size: 28rpx;
}

.recommend-main {
  flex: 1;
  min-width: 0;
}

.recommend-top {
  align-items: flex-start;
  gap: 14rpx;
}

.recommend-name {
  font-size: 31rpx;
  font-weight: 700;
  color: #2b2522;
  margin-bottom: 4rpx;
}

.recommend-score {
  flex: 0 0 auto;
  height: 44rpx;
  line-height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #d95b4f;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.recommend-reason {
  margin-top: 12rpx;
  color: #72564d;
  font-size: 24rpx;
  line-height: 1.5;
}

.reason-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.reason-chip {
  display: inline-flex;
  align-items: center;
  height: 38rpx;
  line-height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(126, 156, 134, 0.12);
  color: #496c52;
  font-size: 20rpx;
}

.recommend-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.recommend-actions {
  gap: 10rpx;
  margin-top: 18rpx;
}

.recommend-actions .btn {
  flex: 1;
  padding: 0 12rpx;
}

.profile-card {
  position: relative;
  padding: 28rpx;
  transition: transform 160ms ease;
}

.profile-card::before {
  content: "";
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  top: 0;
  height: 1rpx;
  background: linear-gradient(90deg, rgba(217, 91, 79, 0), rgba(217, 91, 79, 0.36), rgba(126, 156, 134, 0));
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.profile-head {
  align-items: flex-start;
  gap: 16rpx;
}

.badge-stack {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.publisher-badge {
  padding: 0 12rpx;
  height: 38rpx;
  line-height: 38rpx;
  border-radius: 999rpx;
  background: rgba(242, 216, 167, 0.28);
  color: #73591f;
  font-size: 20rpx;
}

.profile-name {
  display: block;
  font-size: 33rpx;
  font-weight: 700;
  color: #2b2522;
}

.profile-meta {
  display: block;
  margin-top: 5rpx;
  color: #8a7a70;
  font-size: 24rpx;
}

.profile-summary {
  margin-top: 12rpx;
}

.profile-intro {
  margin-top: 12rpx;
  color: #4d443f;
  line-height: 1.58;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(126, 156, 134, 0.09);
  border: 1rpx solid rgba(126, 156, 134, 0.1);
}

.tag-row,
.lifestyle-row,
.trust-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag-row {
  margin-top: 20rpx;
}

.lifestyle-row {
  margin-top: 18rpx;
}

.trust-row {
  margin-top: 16rpx;
}

.trust-badge {
  display: inline-flex;
  align-items: center;
  height: 42rpx;
  line-height: 42rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: rgba(126, 156, 134, 0.12);
  color: #496c52;
}

.trust-badge-primary {
  background: #2b2522;
  color: #fff8f3;
}

.trust-badge-warm {
  background: rgba(242, 216, 167, 0.34);
  color: #73591f;
}

.trust-badge-soft {
  background: rgba(217, 91, 79, 0.1);
  color: #9e4238;
}

.tag-warm {
  background: rgba(242, 216, 167, 0.3);
  color: #73591f;
}

.card-actions {
  gap: 14rpx;
  margin-top: 22rpx;
}

.card-actions .btn {
  flex: 1;
}

.empty-action {
  margin-top: 24rpx;
}
