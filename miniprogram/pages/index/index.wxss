.top-panel {
  margin-top: 4rpx;
  position: relative;
  overflow: hidden;
  background: #fffdfb;
  border-color: rgba(145, 65, 54, 0.1);
}

.top-panel::after {
  content: "喜";
  position: absolute;
  right: 20rpx;
  top: 6rpx;
  color: rgba(184, 58, 47, 0.05);
  font-size: 196rpx;
  line-height: 1;
  font-family: KaiTi, STKaiti, serif;
}

.top-hero {
  align-items: flex-start;
  gap: 16rpx;
}

.festival-hero {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.festival-mark-wrap {
  flex: 0 0 auto;
  width: 96rpx;
  height: 96rpx;
  border-radius: 8rpx;
  background: #b83a2f;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 30rpx rgba(184, 58, 47, 0.2);
}

.festival-mark {
  font-size: 68rpx;
  line-height: 1;
  color: #fff7ed;
  font-weight: 700;
  font-family: KaiTi, STKaiti, serif;
}

.festival-copy {
  flex: 1;
  min-width: 0;
}

.index-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #241d1a;
  line-height: 1.2;
}

.hero-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.soft-chip {
  display: inline-flex;
  align-items: center;
  height: 46rpx;
  line-height: 46rpx;
  padding: 0 16rpx;
  border-radius: 23rpx;
  background: #f5ebe6;
  color: #6f332c;
  font-size: 22rpx;
}

.soft-chip-warm {
  background: #f2ead9;
  color: #7c5a16;
}

.soft-chip-mode {
  background: #f9e7e3;
  color: #a53128;
}

.festival-sub {
  margin-top: 10rpx;
  color: #6a5d56;
  font-size: 24rpx;
  line-height: 1.45;
}

.hero-stat {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 22rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: #f9f1ed;
  border: 1rpx solid rgba(145, 65, 54, 0.08);
}

.hero-stat-number {
  font-size: 42rpx;
  font-weight: 700;
  color: #b83a2f;
  line-height: 1;
}

.hero-stat-copy {
  flex: 1;
  color: #51443f;
  font-size: 24rpx;
  line-height: 1.5;
  text-align: right;
}

.search-row {
  display: grid;
  grid-template-columns: 1fr auto auto;
  gap: 12rpx;
  margin-top: 24rpx;
  align-items: center;
}

.search-input {
  height: 72rpx;
}

.filter-line {
  margin-top: 18rpx;
}

.profile-card {
  position: relative;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.profile-head {
  align-items: flex-start;
}

.badge-stack {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.publisher-badge {
  padding: 0 12rpx;
  height: 38rpx;
  line-height: 38rpx;
  border-radius: 19rpx;
  background: #f9e7e3;
  color: #a53128;
  font-size: 20rpx;
}

.profile-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #241d1a;
}

.profile-meta {
  display: block;
  margin-top: 4rpx;
  color: #746862;
  font-size: 24rpx;
}

.profile-summary {
  margin-top: 12rpx;
}

.profile-intro {
  margin-top: 10rpx;
  color: #51443f;
  line-height: 1.55;
  padding: 14rpx 16rpx;
  border-radius: 8rpx;
  background: #f9f1ed;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.lifestyle-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.trust-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.trust-badge {
  display: inline-flex;
  align-items: center;
  height: 42rpx;
  line-height: 42rpx;
  padding: 0 14rpx;
  border-radius: 21rpx;
  font-size: 22rpx;
  background: #f5ebe6;
  color: #6f332c;
}

.trust-badge-primary {
  background: #b83a2f;
  color: #ffffff;
}

.trust-badge-warm {
  background: #f2ead9;
  color: #7c5a16;
}

.trust-badge-soft {
  background: #f9e7e3;
  color: #a53128;
}

.tag-warm {
  background: #f2ead9;
  color: #7c5a16;
}

.recommend-panel {
  background: #fffdfb;
}

.recommend-head {
  align-items: flex-start;
  gap: 16rpx;
}

.recommend-tools {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.recommend-tool {
  height: 46rpx;
  line-height: 46rpx;
  padding: 0 16rpx;
  border-radius: 23rpx;
  background: #f5ebe6;
  color: #6f332c;
  font-size: 22rpx;
}

.recommend-tool-muted {
  background: #f2ead9;
  color: #7c5a16;
}

.recommend-count {
  flex: 0 0 auto;
  height: 46rpx;
  line-height: 46rpx;
  padding: 0 16rpx;
  border-radius: 23rpx;
  background: #f9e7e3;
  color: #a53128;
  font-size: 22rpx;
}

.recommend-list {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
  margin-top: 18rpx;
}

.recommend-empty {
  margin-top: 18rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  background: #f9f1ed;
  color: #6f332c;
  text-align: center;
  line-height: 1.6;
}

.recommend-empty-action {
  margin-top: 18rpx;
}

.recommend-card {
  padding: 18rpx;
  border-radius: 8rpx;
  background: #fffdfb;
  border: 1rpx solid rgba(145, 65, 54, 0.12);
}

.avatar-recommend {
  width: 88rpx;
  height: 88rpx;
  font-size: 28rpx;
}

.recommend-main {
  flex: 1;
  min-width: 0;
}

.recommend-top {
  align-items: flex-start;
  gap: 14rpx;
}

.recommend-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #33211d;
  margin-bottom: 4rpx;
}

.recommend-score {
  flex: 0 0 auto;
  height: 42rpx;
  line-height: 42rpx;
  padding: 0 14rpx;
  border-radius: 21rpx;
  background: #b83a2f;
  color: #ffffff;
  font-size: 22rpx;
}

.recommend-reason {
  margin-top: 12rpx;
  color: #6f332c;
  font-size: 24rpx;
  line-height: 1.45;
}

.recommend-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.recommend-actions {
  gap: 10rpx;
  margin-top: 18rpx;
}

.recommend-actions .btn {
  flex: 1;
  padding: 0 12rpx;
}

.card-actions {
  margin-top: 22rpx;
}

.empty-action {
  margin-top: 24rpx;
}
