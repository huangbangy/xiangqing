page {
  background-color: #f8f3ef;
  color: #1f2937;
  font-size: 28rpx;
}

button::after {
  border: none;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
  background-color: #f8f3ef;
}

.section {
  margin-bottom: 24rpx;
}

.card {
  background: #fffdfb;
  border: 1rpx solid rgba(145, 65, 54, 0.1);
  border-radius: 8rpx;
  padding: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 12rpx 32rpx rgba(72, 42, 36, 0.07);
}

.card + .card {
  margin-top: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #33211d;
  margin-bottom: 16rpx;
}

.subtle {
  color: #746862;
  font-size: 24rpx;
}

.muted {
  color: #9a8f88;
}

.row {
  display: flex;
  align-items: center;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.row-start {
  display: flex;
  align-items: flex-start;
}

.gap-12 {
  gap: 12rpx;
}

.gap-16 {
  gap: 16rpx;
}

.gap-20 {
  gap: 20rpx;
}

.stack-8 > view + view {
  margin-top: 8rpx;
}

.stack-12 > view + view {
  margin-top: 12rpx;
}

.stack-16 > view + view {
  margin-top: 16rpx;
}

.divider {
  height: 1rpx;
  background: rgba(145, 65, 54, 0.12);
  margin: 20rpx 0;
}

.btn {
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  line-height: 72rpx;
  height: 72rpx;
  box-sizing: border-box;
}

.btn-primary {
  background: #b83a2f;
  color: #ffffff;
}

.btn-ghost {
  background: #f4e8e3;
  color: #6f332c;
}

.btn-danger {
  background: #f9e7e3;
  color: #a53128;
}

.btn-small {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid rgba(145, 65, 54, 0.16);
  border-radius: 8rpx;
  background: #fffdfb;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
}

.textarea {
  min-height: 180rpx;
}

.label {
  font-size: 24rpx;
  color: #6a5d56;
  margin-bottom: 10rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 24rpx;
  background: #f4e8e3;
  color: #6f332c;
  font-size: 22rpx;
}

.chip-active {
  background: #b83a2f;
  color: #ffffff;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 0 14rpx;
  height: 42rpx;
  line-height: 42rpx;
  border-radius: 21rpx;
  background: #f5ebe6;
  color: #6f332c;
  font-size: 22rpx;
}

.tag-soft {
  background: #f9e7e3;
  color: #a53128;
}

.empty {
  padding: 64rpx 24rpx;
  text-align: center;
  color: #94a3b8;
}

.avatar {
  flex: 0 0 auto;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #f4e8e3;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7c382f;
  font-size: 30rpx;
  font-weight: 600;
}

.avatar-lg {
  width: 120rpx;
  height: 120rpx;
  font-size: 36rpx;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.segmented {
  display: flex;
  background: #efe1db;
  border-radius: 8rpx;
  overflow: hidden;
}

.segmented-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 12rpx;
  font-size: 26rpx;
  color: #6f332c;
  background: #efe1db;
}

.segmented-item-active {
  background: #b83a2f;
  color: #ffffff;
}

.progress-track {
  width: 100%;
  height: 14rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #eadbd5;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #b83a2f;
}

.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.form-grid-single {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
}
