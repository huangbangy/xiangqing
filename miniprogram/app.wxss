page {
  min-height: 100vh;
  background-color: #fff8f3;
  background-image:
    linear-gradient(180deg, #fff8f3 0%, #f6faf4 42%, #fbf1ec 100%);
  color: #2b2522;
  font-family: "PingFang SC", "Source Han Sans SC", sans-serif;
  font-size: 28rpx;
}

button::after {
  border: none;
}

button {
  font-family: "PingFang SC", "Source Han Sans SC", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 24rpx 42rpx;
  background-color: transparent;
}

.section {
  margin-bottom: 24rpx;
}

.card {
  position: relative;
  overflow: hidden;
  background: rgba(255, 253, 249, 0.9);
  border: 1rpx solid rgba(139, 63, 52, 0.12);
  border-radius: 16rpx;
  padding: 28rpx;
  box-sizing: border-box;
  box-shadow: 0 18rpx 48rpx rgba(80, 52, 46, 0.1);
  -webkit-backdrop-filter: blur(18rpx);
  backdrop-filter: blur(18rpx);
}

.card + .card {
  margin-top: 18rpx;
}

.section-title {
  font-family: "Songti SC", "Noto Serif SC", serif;
  font-size: 32rpx;
  font-weight: 700;
  color: #2b2522;
  letter-spacing: 0;
  line-height: 1.25;
  margin-bottom: 16rpx;
}

.subtle {
  color: #766b63;
  font-size: 24rpx;
  line-height: 1.55;
}

.muted {
  color: #a0968e;
}

.row {
  display: flex;
  align-items: center;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.row-start {
  display: flex;
  align-items: flex-start;
}

.gap-12 {
  gap: 12rpx;
}

.gap-16 {
  gap: 16rpx;
}

.gap-20 {
  gap: 20rpx;
}

.stack-8 > view + view {
  margin-top: 8rpx;
}

.stack-12 > view + view {
  margin-top: 12rpx;
}

.stack-16 > view + view {
  margin-top: 16rpx;
}

.divider {
  height: 1rpx;
  background: rgba(139, 63, 52, 0.12);
  margin: 22rpx 0;
}

.btn {
  min-width: 0;
  border-radius: 999rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0;
  line-height: 76rpx;
  height: 76rpx;
  box-sizing: border-box;
  transition: transform 160ms ease, opacity 160ms ease;
}

.btn-primary {
  background: linear-gradient(135deg, #d95b4f 0%, #b8493e 100%);
  color: #ffffff;
  box-shadow:
    0 16rpx 34rpx rgba(217, 91, 79, 0.28),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.35);
}

.btn-ghost {
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(139, 63, 52, 0.14);
  color: #8b3f34;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.78);
}

.btn-danger {
  background: #fae7e2;
  color: #a73930;
  border: 1rpx solid rgba(167, 57, 48, 0.16);
}

.btn-small {
  height: 58rpx;
  line-height: 58rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid rgba(139, 63, 52, 0.15);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #2b2522;
  padding: 20rpx 22rpx;
  font-size: 28rpx;
  box-shadow: inset 0 2rpx 6rpx rgba(80, 52, 46, 0.04);
}

.textarea {
  min-height: 188rpx;
  line-height: 1.55;
}

.label {
  font-size: 23rpx;
  color: #8c7d72;
  margin-bottom: 10rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 999rpx;
  background: rgba(126, 156, 134, 0.13);
  color: #496c52;
  font-size: 22rpx;
  font-weight: 600;
}

.chip-active {
  background: #2b2522;
  color: #fff8f3;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 0 16rpx;
  height: 42rpx;
  line-height: 42rpx;
  border-radius: 999rpx;
  background: rgba(126, 156, 134, 0.12);
  color: #4c6f55;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-soft {
  background: rgba(217, 91, 79, 0.1);
  color: #9e4238;
}

.empty {
  padding: 68rpx 28rpx;
  text-align: center;
  color: #8d8178;
  line-height: 1.65;
}

.avatar {
  flex: 0 0 auto;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  background: linear-gradient(135deg, #f2d8a7 0%, #d95b4f 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff8f3;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 14rpx 30rpx rgba(139, 63, 52, 0.18);
}

.avatar-lg {
  width: 124rpx;
  height: 124rpx;
  font-size: 38rpx;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.safe-bottom {
  padding-bottom: calc(42rpx + env(safe-area-inset-bottom));
}

.segmented {
  display: flex;
  padding: 6rpx;
  background: rgba(255, 255, 255, 0.62);
  border: 1rpx solid rgba(139, 63, 52, 0.12);
  border-radius: 16rpx;
  overflow: hidden;
}

.segmented-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 12rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #8b3f34;
  background: transparent;
}

.segmented-item-active {
  background: #2b2522;
  color: #fff8f3;
}

.progress-track {
  width: 100%;
  height: 14rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(139, 63, 52, 0.12);
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #7e9c86 0%, #d95b4f 100%);
}

.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.form-grid-single {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
}
